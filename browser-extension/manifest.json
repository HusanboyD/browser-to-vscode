{
  "manifest_version": 3,
  "name": "Browser to VS Code",
  "version": "1.0.0",
  "description": "Send selected browser text to VS Code.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Browser to VS Code"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}